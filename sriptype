#!/usr/bin/env python3
"""SRIPType - Entry point script.

This script can be run directly:
  1. Via absolute path:  /path/to/SRIPType/sriptype
  2. Via PATH:           export PATH=/path/to/SRIPType:$PATH && sriptype
  3. Via pip install:    pip install . && sriptype
"""

import os
import sys

# Ensure the project root is in sys.path so sriptype_modules can be imported
# This allows running the script directly without installation
script_dir = os.path.dirname(os.path.abspath(__file__))
if script_dir not in sys.path:
    sys.path.insert(0, script_dir)

from sriptype_modules.cli import main

if __name__ == "__main__":
    main()
